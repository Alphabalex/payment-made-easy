{
    "name": "nexuspay/payment-made-easy",
    "description": "A Laravel package for handling payments with multiple gateways (Paystack, Flutterwave, Stripe, Seerbit, etc.)",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.83|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^8.83|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.10|^10.5|^11.0",
        "orchestra/testbench": "^6.24|^7.0|^8.0|^9.0|^10.0|^11.0",
        "stripe/stripe-php": "^17.4"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "NexusPay\\PaymentMadeEasy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NexusPay\\PaymentMadeEasy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NexusPay\\PaymentMadeEasy\\PaymentServiceProvider"
            ],
            "aliases": {
                "Payment": "NexusPay\\PaymentMadeEasy\\Facades\\Payment"
            }
        }
    },
    "authors": [
        {
            "name": "Balogun Abdulquddus",
            "email": "babusunnah@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "ext-bcmath": "For accurate minor-unit conversion in AbstractPaymentDriver::convertAmount()",
        "stripe/stripe-php": "^17.4 Required for StripeDriver and Stripe webhook handling (composer require stripe/stripe-php)"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit --testsuite Unit",
        "test:feature": "vendor/bin/phpunit --testsuite Feature"
    }
}